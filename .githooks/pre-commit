#!/bin/sh

RED='\033[0;31m'
NC='\033[0m'

violation=0

check_pattern() {
  pattern="$1"
  label="$2"
  for file in $(git diff --cached --name-only --diff-filter=ACMRT); do
    [ ! -f "$file" ] && continue
    blob=$(git show :"$file" 2>/dev/null) || continue
    if echo "$blob" | grep -qE "$pattern"; then
      echo "${RED}❌ BLOCKED: $label detected in $file${NC}"
      echo "$blob" | grep -En "$pattern" | head -3
      violation=1
    fi
  done
}

check_pattern 'gh[pousr]_[A-Za-z0-9_]+'               'GitHub token (ghp_/gho_/ghu_/ghs_/ghr_)'
check_pattern 'AIzaSy[A-Za-z0-9_-]+'                   'Google API key (AIzaSy)'
check_pattern 'GOCSPX-[A-Za-z0-9_-]+'                  'Google OAuth secret (GOCSPX)'
check_pattern 'sk-[A-Za-z0-9]{20,}'                    'API secret key (sk-)'
check_pattern 'AKIA[0-9A-Z]{16}'                        'AWS access key (AKIA)'
check_pattern 'BEGIN (RSA |EC )?PRIVATE KEY'            'Private key PEM'

if [ "$violation" -eq 1 ]; then
  echo "${RED}Use: git commit --no-verify to override (if false positive)${NC}"
  exit 1
fi

exit 0
