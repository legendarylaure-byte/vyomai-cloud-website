# Environment Configuration for VyomAi

# Application Environment
NODE_ENV=production
PORT=5000

# Google Gemini AI Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase (REQUIRED in production — server refuses to start without it)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project-id",...}

# Session Security (generate with: openssl rand -base64 32)
SESSION_SECRET=generate_a_random_secure_string_here

# Database Configuration (for future PostgreSQL migration)
DATABASE_URL=postgresql://user:password@localhost:5432/vyomai

# Email Service Configuration
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=resend
SMTP_PASSWORD=your_resend_api_key_here
EMAIL_PROVIDER=smtp

# Fonepay Payment Gateway Configuration
FONEPAY_MERCHANT_CODE=your_fonepay_merchant_code_here
FONEPAY_SECRET_KEY=your_fonepay_secret_key_here
FONEPAY_API_URL=https://fonepay.com/api/

# Google OAuth (for admin Google Sign-In)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Admin Google Email Whitelist (comma-separated, leave empty to allow all)
ADMIN_GOOGLE_EMAILS=you@yourdomain.com,admin@yourdomain.com

# Social Media Integration (optional)
SOCIAL_MEDIA_ENCRYPTION_KEY=generate_a_random_key_here

# Optional: Analytics and Monitoring
SENTRY_DSN=your_sentry_dsn_here
